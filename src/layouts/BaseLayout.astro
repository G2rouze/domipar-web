---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Domicile Partagé à Asfeld (08) pour personnes atteintes d'Alzheimer ou maladie apparentée",
  ogImage = '/assets/accueil-render-home.png',
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = 'https://domipar.netlify.app';
const canonicalUrl = `${siteUrl}${currentPath}`;
const ogImageUrl = `${siteUrl}${ogImage}`;

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/projet', label: 'Le Projet' },
  { href: '/qui-sommes-nous', label: 'Qui sommes-nous ?' },
  { href: '/la-maison', label: 'La Maison' },
  { href: '/asfeld', label: 'Asfeld' },
  { href: '/temoignages', label: 'Témoignages' },
  { href: '/actualites', label: 'Actualités' },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Domipar</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} — Domipar`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Domipar" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — Domipar`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="google-site-verification" content="kGhUBlRMzZ-PVEEJXWG9wYrQpPHCy9KrZreGSERMHMw" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-033Q14DDM6"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-033Q14DDM6');
    </script>
    <link rel="icon" href="/assets/domipar_logo.png" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body class="flex flex-col min-h-screen">

    <!-- Navigation -->
    <header class="bg-[#faf8f5] border-b border-[#d4e4d0] sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-8 h-20 flex items-center justify-between">
        <a href="/" class="flex-shrink-0">
          <img src="/assets/domipar_logo.png" alt="Domipar" class="h-10 w-auto" />
        </a>

        <ul class="hidden md:flex items-center gap-9">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class={`text-sm font-medium transition-colors ${
                  currentPath.startsWith(link.href)
                    ? 'text-[#2c3e35] font-semibold'
                    : 'text-[#5a7a68] hover:text-[#2c3e35]'
                }`}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <a
          href="/contact"
          class="hidden md:inline-flex items-center px-6 py-2.5 rounded-full border border-[#2c3e35] text-[#2c3e35] text-sm font-medium hover:bg-[#f0ede8] transition-colors"
        >
          Nous contacter
        </a>
        <a
          href="https://www.helloasso.com/associations/domipar-asfeld/formulaires/1"
          target="_blank"
          rel="noopener"
          class="hidden md:inline-flex items-center px-6 py-2.5 rounded-full bg-[#d4e4d0] text-[#2c3e35] text-sm font-semibold hover:bg-[#c4d8bf] transition-colors"
        >
          Nous soutenir
        </a>

        <!-- Burger mobile -->
        <button id="burger" class="md:hidden p-2 text-[#2c3e35]" aria-label="Menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 12h18M3 6h18M3 18h18" stroke-linecap="round"/>
          </svg>
        </button>
      </nav>

      <!-- Menu mobile -->
      <div id="mobile-menu" class="hidden md:hidden bg-[#faf8f5] border-t border-[#d4e4d0] px-8 py-4">
        <ul class="flex flex-col gap-4">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-[#5a7a68] hover:text-[#2c3e35] font-medium">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/contact" class="inline-flex px-6 py-2.5 rounded-full border border-[#2c3e35] text-[#2c3e35] text-sm font-medium">
              Nous contacter
            </a>
          </li>
          <li>
            <a href="https://www.helloasso.com/associations/domipar-asfeld/formulaires/1" target="_blank" rel="noopener" class="inline-flex px-6 py-2.5 rounded-full bg-[#d4e4d0] text-[#2c3e35] text-sm font-semibold">
              Nous soutenir
            </a>
          </li>
        </ul>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-[#1e2e27] text-[#7a9a88] py-14 px-8">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between gap-12 mb-10">
          <!-- Brand -->
          <div class="max-w-xs">
            <p class="font-serif text-[#d4e4d0] text-lg font-bold tracking-widest mb-3">DOMIPAR</p>
            <p class="text-sm leading-relaxed">
              Domicile Partagé à Asfeld (08) pour personnes atteintes d'Alzheimer ou maladie apparentée
            </p>
          </div>

          <!-- Colonnes -->
          <div class="flex gap-16 flex-wrap">
            <div>
              <p class="text-[#d4e4d0] text-xs font-semibold uppercase tracking-wider mb-4">En savoir plus</p>
              <ul class="space-y-2 text-sm">
                <li><a href="/projet" class="hover:text-[#d4e4d0] transition-colors">Projet</a></li>
                <li><a href="/qui-sommes-nous" class="hover:text-[#d4e4d0] transition-colors">Qui sommes-nous ?</a></li>
                <li><a href="/la-maison" class="hover:text-[#d4e4d0] transition-colors">La Maison</a></li>
                <li><a href="/asfeld" class="hover:text-[#d4e4d0] transition-colors">Asfeld</a></li>
                <li><a href="/actualites" class="hover:text-[#d4e4d0] transition-colors">Actualités</a></li>
              </ul>
            </div>
            <div>
              <p class="text-[#d4e4d0] text-xs font-semibold uppercase tracking-wider mb-4">Nous rejoindre</p>
              <ul class="space-y-2 text-sm">
                <li><a href="/contact" class="hover:text-[#d4e4d0] transition-colors">Nous contacter</a></li>
                <li><a href="https://www.helloasso.com/associations/domipar-asfeld/" target="_blank" rel="noopener" class="hover:text-[#d4e4d0] transition-colors">Faire un don</a></li>
              </ul>
            </div>
            <div>
              <p class="text-[#d4e4d0] text-xs font-semibold uppercase tracking-wider mb-4">Nos réseaux</p>
              <ul class="space-y-2 text-sm">
                <li><a href="https://www.facebook.com/profile.php?id=61567917167886" target="_blank" rel="noopener" class="hover:text-[#d4e4d0] transition-colors">Facebook</a></li>
                <li><a href="https://www.instagram.com/domipar08/" target="_blank" rel="noopener" class="hover:text-[#d4e4d0] transition-colors">Instagram</a></li>
                <li><a href="https://www.linkedin.com/company/domipar08/" target="_blank" rel="noopener" class="hover:text-[#d4e4d0] transition-colors">LinkedIn</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="border-t border-[#2c3e35] pt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs">
          <span>© 2026 Domipar — Association loi 1901</span>
          <a href="/mentions-legales" class="hover:text-[#d4e4d0] transition-colors">Mentions légales</a>
        </div>
      </div>
    </footer>

    <script>
      const burger = document.getElementById('burger');
      const mobileMenu = document.getElementById('mobile-menu');
      burger?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));

      // Netlify Identity redirect
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', user => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>

  </body>
</html>
