---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Nous contacter" description="Contactez l'association Domipar pour toute question sur le domicile partagé Alzheimer d'Asfeld.">

  <!-- Hero -->
  <section class="bg-[#d4e4d0]">
    <div class="max-w-[1440px] mx-auto px-20 py-20 flex flex-col items-center gap-4 text-center">
      <h1 class="font-serif text-[52px] text-[#2c3e35]">Nous contacter</h1>
      <p class="text-[#5a7a68] text-[17px] w-[720px]">
        Pour nous contacter, merci d'entrez vos information et votre message dans le formulaire ci-dessous.
      </p>
    </div>
  </section>

  <!-- Section contact -->
  <section class="bg-[#faf8f5]">
    <div class="max-w-[1440px] mx-auto px-20 py-20 flex gap-20">

      <!-- Colonne gauche -->
      <div class="flex flex-col gap-6 w-[480px] shrink-0">
        <h2 class="font-serif text-[32px] text-[#2c3e35]">Nous écrire</h2>
        <p class="text-[#5a7a68] text-base leading-[1.6] w-[480px]">
          Pour nous contacter, merci d'entrez vos information et votre message dans le formulaire ci-dessous.
        </p>
        <div class="flex items-center gap-3">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5a7a68" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="text-[#5a7a68] text-[15px]">MVA 77 – 122 bis rue du Barbâtre – 51100 Reims</span>
        </div>
        <div class="flex items-center gap-3">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5a7a68" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span class="text-[#5a7a68] text-[15px]">domipar08@gmail.com</span>
        </div>
        <div class="flex items-center gap-4">
          <a href="https://www.facebook.com/profile.php?id=61567917167886" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5a7a68" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/domipar08/" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5a7a68" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/domipar08/" target="_blank" rel="noopener" class="hover:opacity-70 transition-opacity">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#5a7a68" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>

      <!-- Formulaire -->
      <div class="flex-1">
        <div class="bg-white rounded-[20px] p-10 flex flex-col gap-5 border border-[#d4e4d0]">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="flex flex-col gap-5"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><label>Ne pas remplir : <input name="bot-field" /></label></p>

            <div class="flex flex-col gap-1.5">
              <label for="nom" class="text-[#5a7a68] text-[13px]">Nom</label>
              <input
                id="nom" type="text" name="nom" required
                class="w-full h-12 px-4 rounded-xl border border-[#d4e4d0] bg-[#faf8f5] text-[#2c3e35] focus:outline-none focus:border-[#5a7a68] transition-colors"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-[#5a7a68] text-[13px]">E-mail</label>
              <input
                id="email" type="email" name="email" required
                class="w-full h-12 px-4 rounded-xl border border-[#d4e4d0] bg-[#faf8f5] text-[#2c3e35] focus:outline-none focus:border-[#5a7a68] transition-colors"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="message" class="text-[#5a7a68] text-[13px]">Message</label>
              <textarea
                id="message" name="message" required rows="5"
                class="w-full px-4 py-3 rounded-xl border border-[#d4e4d0] bg-[#faf8f5] text-[#2c3e35] focus:outline-none focus:border-[#5a7a68] transition-colors resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full h-[52px] rounded-full bg-[#2c3e35] text-white text-base font-normal hover:bg-[#1e2e27] transition-colors"
            >
              Envoyer
            </button>
          </form>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
