---
import BaseLayout from '../layouts/BaseLayout.astro';

const actualites = [
  { date: '24 MARS 2026', titre: 'Projection de film et débat public', texte: 'Rejoignez-nous pour une soirée ouverte à tous autour du projet et de la maladie d\'Alzheimer.' },
  { date: '18-19-20 NOVEMBRE 2025', titre: 'Voyage d\'étude à Berlin avec Dialog Health', texte: 'À la découverte des colocations allemandes, avec Dialog Health.', href: 'https://youtu.be/bO_fLlwUQwY' },
  { date: '23-24-25 OCTOBRE 2025', titre: 'Formation à la Validation selon Naomi Feil', texte: 'Premier module par Kathia Munsch, organisé pour les professionnels.' },
  { date: '23 SEPTEMBRE 2025', titre: 'Remise du Trophée CASALIS', texte: 'Colocation Alzheimer, Système d\'Accompagnement vers le Logement Inclusif et Solidaire.' },
  { date: '1er ET 4 SEPTEMBRE 2025', titre: 'Stand Campus Séniors — Foire de Châlons', texte: 'Présence sur le stand de Campus Séniors de la Foire de Châlons et présentation du projet.' },
  { date: '24 JUIN 2025', titre: 'Projection à Asfeld du film « La maison de l\'instant présent »', texte: 'Projection du film à Asfeld.', href: 'https://youtu.be/qPeGfU2EGsw' },
  { date: '17 MAI 2025', titre: 'Stand à la Fête du printemps — Ets Maréchalle à Asfeld', texte: '2 tombolas au profit de DOMIPAR, organisées par les Ets Maréchalle à Asfeld.', href: 'https://domipar.fr/wp-content/uploads/2025/05/flyer-printemps-marechalle-1.pdf' },
  { date: '11 AVRIL 2025', titre: 'Participation au Ministère de la Santé', texte: '« Place des colocations Alzheimer dans l\'offre d\'habitat »', href: 'https://www.fondation-mederic-alzheimer.org/la-place-des-colocations-alzheimer-dans-loffre-dhabitat-des-personnes-agees/' },
  { date: '28 FÉVRIER 2025', titre: 'Assemblée des Sociétaires — Crédit Agricole', texte: 'Présentation du projet lors de l\'Assemblée des Sociétaires de la Caisse Locale du Crédit Agricole.' },
  { date: '17 FÉVRIER 2025', titre: 'AG de la Fédération de l\'ADMR', texte: 'Présentation du projet lors de l\'Assemblée Générale de la Fédération de l\'ADMR.' },
  { date: '11 FÉVRIER 2025', titre: 'Rencontre avec Mme Poittevin, direction santé Grand Est', texte: 'Rencontre à Asfeld avec Madame Poittevin, direction santé pour la région Grand Est.' },
  { date: '16 JANVIER 2025', titre: 'Domipar sur France Bleu — « Bienvenue chez vous »', texte: 'Domipar et le Dr. Vuillemin dans l\'émission « Bienvenue chez vous » sur France Bleu.', href: 'https://www.francebleu.fr/emissions/bienvenue-chez-vous-on-part-en-balade-ici-champagne-ardenne/on-part-en-balade-a-asfeld-8352552' },
  { date: '25 DÉCEMBRE 2024', titre: 'Les Petites Pierres : 20 000 € récoltés en 43 jours', texte: 'Fin de la campagne de financement participatif sur les Petites Pierres.', href: 'https://www.lespetitespierres.org/projet/creation-dune-colocation-pour-personnes-alzheimer/' },
  { date: '20 DÉCEMBRE 2024', titre: 'Permis de construire déposé à Asfeld', texte: 'Permis de construire déposé à Asfeld, obtenu en mai 2025.' },
  { date: '19 DÉCEMBRE 2024', titre: 'Interview « Echos du Rethélois » sur RCF Reims-Ardennes', texte: 'Interview « Echos du Rethélois » diffusée sur RCF Reims-Ardennes.', href: 'https://www.rcf.fr/actualite/echos-du-rethelois/embed?episodeId=541753' },
  { date: '17 DÉCEMBRE 2024', titre: 'Rencontres territoriales de l\'Habitat Partagé à Paris', texte: 'Rencontres territoriales de l\'Habitat Partagé et Accompagné à Paris.', href: 'https://www.reseau-hapa.eu/inscrivez-vous-a-paris-le-17-decembre/' },
  { date: '26 NOVEMBRE 2024', titre: 'Table ronde sur la protection juridique des personnes vulnérables', texte: 'Table ronde sur la protection juridique des personnes vulnérables.', href: 'https://www.erege.fr/champagne-ardenne/actu-travaux/table-ronde-la-protection-juridique-des-personnes-vulnerables/31/actu.html' },
  { date: '5 OCTOBRE 2024', titre: 'Création de l\'association DOMIPAR ASFELD', texte: 'Création de l\'association DOMIPAR ASFELD qui fera vivre la maison une fois ouverte.' },
];
---

<BaseLayout title="Actualités" description="Suivez toutes les actualités de l'association Domipar — domicile partagé Alzheimer à Asfeld (Ardennes).">

  <!-- Hero -->
  <section class="bg-[#d4e4d0]">
    <div class="max-w-[1440px] mx-auto px-20 py-20 flex flex-col items-center gap-4 text-center">
      <h1 class="font-serif text-[52px] font-bold text-[#2c3e35]">Actualités</h1>
      <p class="text-[#5a7a68] text-[17px] leading-[1.55] w-[700px]">
        Suivez les dernières nouvelles et étapes du projet Domipar,<br/>une colocation innovante pour les personnes atteintes de la maladie d'Alzheimer.
      </p>
    </div>
  </section>

  <!-- Grille actualités -->
  <section class="bg-[#faf8f5]">
    <div class="max-w-[1440px] mx-auto px-20 py-[72px] flex flex-col gap-6">
      <div class="grid grid-cols-3 gap-6">
        {actualites.map((actu) => (
          actu.href ? (
            <a href={actu.href} target="_blank" rel="noopener" class="bg-white rounded-[20px] overflow-hidden flex flex-col border border-[#d4e4d0] hover:border-[#5a7a68] hover:shadow-md transition-all">
              <div class="h-1 bg-[#5a7a68]"></div>
              <div class="p-5 flex flex-col gap-[10px]">
                <time class="text-[#5a7a68] text-[11px] font-semibold tracking-[1.5px] uppercase">{actu.date}</time>
                <h2 class="font-serif text-[17px] font-semibold text-[#2c3e35] leading-[1.35]">{actu.titre}</h2>
                <p class="text-[#5a7a68] text-sm leading-[1.55]">{actu.texte}</p>
                <span class="text-[#2c3e35] text-[13px] font-medium mt-auto">En savoir plus →</span>
              </div>
            </a>
          ) : (
            <article class="bg-white rounded-[20px] overflow-hidden flex flex-col border border-[#d4e4d0]">
              <div class="h-1 bg-[#5a7a68]"></div>
              <div class="p-5 flex flex-col gap-[10px]">
                <time class="text-[#5a7a68] text-[11px] font-semibold tracking-[1.5px] uppercase">{actu.date}</time>
                <h2 class="font-serif text-[17px] font-semibold text-[#2c3e35] leading-[1.35]">{actu.titre}</h2>
                <p class="text-[#5a7a68] text-sm leading-[1.55]">{actu.texte}</p>
              </div>
            </article>
          )
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
