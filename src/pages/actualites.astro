---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allActus = await getCollection('actualites');
const actualites = allActus.sort((a, b) => b.data.date.localeCompare(a.data.date));
const formatDate = (iso: string) => new Date(iso + 'T12:00:00').toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).toUpperCase();
---

<BaseLayout title="Actualités" description="Suivez toutes les actualités de l'association Domipar — domicile partagé Alzheimer à Asfeld (Ardennes).">

  <!-- Hero -->
  <section class="bg-[#d4e4d0]">
    <div class="max-w-[1440px] mx-auto px-4 md:px-20 py-10 md:py-20 flex flex-col items-center gap-4 text-center">
      <h1 class="font-serif text-[30px] md:text-[52px] font-bold text-[#2c3e35]">Actualités</h1>
      <p class="text-[#5a7a68] text-base md:text-[17px] leading-[1.55] max-w-xl">
        Suivez les dernières nouvelles et étapes du projet Domipar,<br class="hidden md:block"/>une colocation innovante pour les personnes atteintes de la maladie d'Alzheimer.
      </p>
    </div>
  </section>

  <!-- Grille actualités -->
  <section class="bg-[#faf8f5]">
    <div class="max-w-[1440px] mx-auto px-4 md:px-20 py-10 md:py-[72px] flex flex-col gap-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {actualites.map((actu) => (
          actu.data.href ? (
            <a href={actu.data.href} target="_blank" rel="noopener" class="bg-white rounded-[20px] overflow-hidden flex flex-col border border-[#d4e4d0] hover:border-[#5a7a68] hover:shadow-md transition-all">
              <div class="h-1 bg-[#5a7a68]"></div>
              <div class="p-5 flex flex-col gap-[10px]">
                <time class="text-[#5a7a68] text-[11px] font-semibold tracking-[1.5px] uppercase">{formatDate(actu.data.date)}</time>
                <h2 class="font-serif text-[17px] font-semibold text-[#2c3e35] leading-[1.35]">{actu.data.titre}</h2>
                <p class="text-[#5a7a68] text-sm leading-[1.55]">{actu.data.texte}</p>
                <span class="text-[#2c3e35] text-[13px] font-medium mt-auto">En savoir plus →</span>
              </div>
            </a>
          ) : (
            <article class="bg-white rounded-[20px] overflow-hidden flex flex-col border border-[#d4e4d0]">
              <div class="h-1 bg-[#5a7a68]"></div>
              <div class="p-5 flex flex-col gap-[10px]">
                <time class="text-[#5a7a68] text-[11px] font-semibold tracking-[1.5px] uppercase">{formatDate(actu.data.date)}</time>
                <h2 class="font-serif text-[17px] font-semibold text-[#2c3e35] leading-[1.35]">{actu.data.titre}</h2>
                <p class="text-[#5a7a68] text-sm leading-[1.55]">{actu.data.texte}</p>
              </div>
            </article>
          )
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
